# ProjectHub — Environment Variables
# Copy this file to .env and adjust values for your environment.
#
#   cp .env.example .env

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_URL=postgresql://projecthub:projecthub_secret@localhost:5432/projecthub_db

# ── MongoDB ─────────────────────────────────────────────────────────
MONGO_URL=mongodb://projecthub:projecthub_secret@localhost:27017
MONGO_DB_NAME=projecthub_logs

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
